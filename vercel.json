{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "Logo-Camisa-Preta-1.png", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/Logo-Camisa-Preta-1.png", "dest": "Logo-Camisa-Preta-1.png" },
    { "src": "/(.*)", "dest": "index.html" }
  ]
}
